# Public
NEXT_PUBLIC_SITE_URL=https://mediaexpress.ro

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=contact@mediaexpress.ro
# IMPORTANT pentru deliverability cold outreach: NU folosi noreply@.
# Folosește o adresă personală (nume + branź) ca în exemplul de mai jos.
FROM_EMAIL=Andrei Popescu <andrei@mediaexpress.ro>
# Persona folosită în AI-generated outreach + semnătura emailurilor reci.
SENDER_NAME=Andrei Popescu

# Stripe (plati card + abonamente)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Database (Railway Postgres)
DATABASE_URL=postgres://user:pass@host:port/db

# NextAuth v5 (cont client)
# Generate: openssl rand -base64 32
AUTH_SECRET=change_me_to_random_32_chars_min
AUTH_URL=https://mediaexpress.ro

# Admin auth (panel admin, separat de contul client)
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_in_production
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars

# Extensia Chrome LinkedIn — secret pre-partajat pentru /api/extension/*
# Generate: openssl rand -hex 24. Aceeasi valoare se pune in popup-ul extensiei.
EXTENSION_API_KEY=change_me_to_a_long_random_string

# Cloudinary (upload poze articol — max 3/articol)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=mediaexpres

# OpenAI (generare articol AI + outreach emails + calendar editorial)
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# Modelul folosit pentru articole lungi / press release / calendar editorial
OPENAI_MODEL=gpt-4o
# Modelul folosit pentru sarcini scurte (outreach emails, title variants)
OPENAI_MODEL_FAST=gpt-4o-mini
